{
  "name": "@scrawn/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "./clean_build.sh",
    "rebuild": "cd packages/scrawn && bun run build",
    "clean": "cd packages/scrawn && bun run clean",
    "format": "bunx prettier --write .",
    "changeset": "changeset",
    "release": "bun run build --filter @scrawn/core --filter @scrawn/analytics && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@types/node": "^24.10.0",
    "typescript": "^5.3.0"
  }
}
