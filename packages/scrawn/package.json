{
  "name": "@scrawn/core",
  "version": "0.0.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node ./scripts/copy-generated.cjs",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "gen": "node ./scripts/gen-proto.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "proto:pull": "git submodule update --remote --merge proto",
    "proto:push": "cd proto && git add . && git commit -s -m \"$1\" && git push && cd .."
  },
  "dependencies": {
    "zod": "^4.1.12",
    "@grpc/grpc-js": "^1.13.1",
    "chalk": "^5.6.2",
    "google-protobuf": "^4.0.2",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "vitest": "1.6.1",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "1.6.1",
    "grpc-tools": "^1.13.1",
    "ts-protoc-gen": "^0.15.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
