{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scrawn Config",
  "type": "object",
  "properties": {
    "scrawn": {
      "type": "object",
      "properties": {
        "directory": {
          "type": "string",
          "description": "Output directory for generated tag/biller files"
        },
        "serverUrl": {
          "type": "string",
          "description": "URL of the Scrawn server"
        }
      }
    }
  }
}
